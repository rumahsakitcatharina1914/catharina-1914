// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Model untuk Instagram Feeds
model InstagramFeed {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  href      String   @db.VarChar(500)
  thumbnail String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("instagram_feeds")
}

// Model untuk Messages (Pesan Masuk)
model Message {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  phone     String   @db.VarChar(50)
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("messages")
}

// Model untuk Doctors
model Doctor {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(255)
  specialization String   @db.VarChar(255)
  schedule       Json?    // Menyimpan jadwal dalam format JSON
  image          String?  @db.VarChar(500)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("doctors")
}

//Model untuk berita 
model News {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String   @db.Text
  content     String   @db.LongText
  thumbnail   String
  images      Json?    @default("[]") 
  category    String   @default("umum")
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Layanan {
  id          Int      @id @default(autoincrement())
  num         String   @db.VarChar(10)   // "01", "02", dst
  title       String   @db.VarChar(255)
  short       String   @db.VarChar(255)  // subtitle singkat
  description String   @db.Text
  features    Json     @default("[]")    // array string
  schedule    String?  @db.VarChar(255)
  image       String?  @db.VarChar(500)
  color       String   @default("#0077b6") @db.VarChar(20)
  bg          String   @default("#e0f2fe") @db.VarChar(20)
  slug        String   @unique
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("layanan")
}

model Fasilitas {
  id          Int      @id @default(autoincrement())
  label       String   @db.VarChar(255)
  description String?  @db.Text          // deskripsi lengkap
  image       String?  @db.VarChar(500)
  isLarge     Boolean  @default(false)   // col-span-2 row-span-2
  isWide      Boolean  @default(false)   // col-span-2
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("fasilitas")
}